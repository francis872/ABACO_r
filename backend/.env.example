# Variables de entorno - ÁBACO Backend
# Copia este archivo como .env y completa los valores

# Servidor
PORT=5000
NODE_ENV=development

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=abaco_db
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# JWT
JWT_SECRET=abaco_jwt_secreto_muy_seguro_cambiar_en_produccion
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=abaco_refresh_secreto_cambiar_en_produccion
JWT_REFRESH_EXPIRES_IN=7d

# CORS - URL del frontend
FRONTEND_URL=http://localhost:5173

# Archivos
MAX_FILE_SIZE=10mb
UPLOAD_PATH=./uploads
